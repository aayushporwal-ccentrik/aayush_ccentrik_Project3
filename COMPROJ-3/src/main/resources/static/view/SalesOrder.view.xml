<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    controllerName="punit.controller.SalesOrder">

    <Page title="Sales Order Management System" showHeader="true" enableScrolling="true">

        <!-- OPERATION SELECTION BUTTONS — unchanged -->
        <Panel expandable="false" headerText="Select Operation"
            class="sapUiLargeMargin sapUiResponsiveMargin"
            visible="{/showOperationSelector}">

            <VBox alignItems="Center" class="sapUiMediumMargin">
                <HBox justifyContent="Center" class="sapUiSmallMargin">

                    <Button text="Create"
                        type="Accept"
                        press="onSelectCreate"
                        icon="sap-icon://add"
                        width="150px"
                        class="sapUiSmallMargin"/>

                    <Button text="Read"
                        type="Emphasized"
                        press="onSelectRead"
                        icon="sap-icon://search"
                        width="150px"
                        class="sapUiSmallMargin"/>

                    <Button text="Update"
                        type="Information"
                        press="onSelectUpdate"
                        icon="sap-icon://edit"
                        width="150px"
                        class="sapUiSmallMargin"/>

                </HBox>
            </VBox>

        </Panel>

        <!-- ═══════════════════════════════════════════ -->
        <!--                CREATE SECTION               -->
        <!-- ═══════════════════════════════════════════ -->

        <Panel expandable="false" headerText="Create New Sales Order"
            class="sapUiLargeMargin sapUiResponsiveMargin"
            visible="{/showCreatePanel}">

            <f:SimpleForm id="createCombinedForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                columnsXL="2"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">

                <f:content>

                    <!-- ── SO HEADER FIELDS ── -->
                    <core:Title text="Sales Order Header" />

                    <Label text="SO Number (optional)" />
                    <Input id="createSoNumber"
                        value="{/createPayload/salesOrderNumber}"
                        placeholder="Leave blank to auto-generate"
                        type="Number"/>

                    <Label text="Order Date *" />
                    <DatePicker id="createOrderDate"
                        value="{/createPayload/dateOfOrder}"
                        displayFormat="yyyy-MM-dd"
                        valueFormat="yyyy-MM-dd"
                        placeholder="Select order date"
                        required="true"/>

                    <Label text="Delivery Date" />
                    <DatePicker id="createDeliveryDate"
                        value="{/createPayload/dateOfDelivery}"
                        displayFormat="yyyy-MM-dd"
                        valueFormat="yyyy-MM-dd"
                        placeholder="Select delivery date"/>

                    <!-- ✅ NEW: Customer field with F4 Help button -->
                    <Label text="Customer ID *" />
                    <HBox>
                        <Input id="createCustomerId"
                            value="{/createPayload/customer/customerId}"
                            placeholder="Enter customer ID"
                            required="true"
                            width="70%"/>
                        
                        <!-- ✅ NEW: F4 Help button -->
                        <Button icon="sap-icon://value-help"
                            press="onCustomerF4Help"
                            tooltip="Click to select customer (F4)"
                            width="auto"
                            class="sapUiSmallMargin"/>
                    </HBox>

                    <!-- ✅ NEW: Display selected customer name -->
                    <Label text="Customer Name" />
                    <Text text="{/createPayload/customer/name}"
                        class="sapUiSmallMargin"/>

                    <!-- ── SO ITEM FIELDS ── -->
                    <core:Title text="Sales Order Item" />

                    <Label text="Material" />
                    <Input id="createItemMaterial"
                        value="{/createPayload/material}"
                        placeholder="Enter material"/>

                    <Label text="Quantity" />
                    <Input id="createItemQuantity"
                        value="{/createPayload/quantity}"
                        placeholder="Enter quantity"
                        type="Number"/>

                    <Label text="UOM" />
                    <Input id="createItemUom"
                        value="{/createPayload/uom}"
                        placeholder="Enter unit of measurement"/>

                </f:content>

            </f:SimpleForm>

            <Toolbar class="sapUiSmallMargin">
                <Button text="Save" type="Accept" press="onSaveCombined" icon="sap-icon://save"/>
                <Button text="Back" type="Default" press="onBack" icon="sap-icon://nav-back"/>
            </Toolbar>

        </Panel>

        <!-- ═══════════════════════════════════════════ -->
        <!--                 READ SECTION                -->
        <!-- ═══════════════════════════════════════════ -->

        <Panel expandable="false" headerText="View All Sales Orders"
            class="sapUiLargeMargin sapUiResponsiveMargin"
            visible="{/showReadPanel}">

            <Toolbar class="sapUiSmallMargin">
                <Button text="Load Data" type="Default" press="onLoadData" icon="sap-icon://refresh"/>
                <Button text="Back" type="Default" press="onBack" icon="sap-icon://nav-back"/>
            </Toolbar>

            <!-- SO Header Table -->
            <Panel expandable="false" headerText="SO Header"
                class="sapUiSmallMargin">

                <t:Table id="idHeaderTable"
                    selectionMode="None"
                    visibleRowCount="5"
                    class="sapUiSmallMargin">

                    <t:columns>
                        <t:Column width="120px">
                            <Label text="Order No"/>
                            <t:template>
                                <Text text="{salesOrderNumber}"/>
                            </t:template>
                        </t:Column>

                        <t:Column>
                            <Label text="Order Date"/>
                            <t:template>
                                <Text text="{dateOfOrder}"/>
                            </t:template>
                        </t:Column>

                        <t:Column>
                            <Label text="Delivery Date"/>
                            <t:template>
                                <Text text="{dateOfDelivery}"/>
                            </t:template>
                        </t:Column>

                        <!-- ✅ NEW: Display Customer Name in table -->
                        <t:Column>
                            <Label text="Customer ID"/>
                            <t:template>
                                <Text text="{customer/customerId}"/>
                            </t:template>
                        </t:Column>

                        <t:Column>
                            <Label text="Customer Name"/>
                            <t:template>
                                <Text text="{customer/name}"/>
                            </t:template>
                        </t:Column>
                    </t:columns>

                </t:Table>

            </Panel>

            <!-- SO Item Table -->
            <Panel expandable="false" headerText="SO Items"
                class="sapUiSmallMargin">

                <t:Table id="idItemTable"
                    selectionMode="None"
                    visibleRowCount="5"
                    class="sapUiSmallMargin">

                    <t:columns>
                        <t:Column width="100px">
                            <Label text="Item No"/>
                            <t:template>
                                <Text text="{itemNumber}"/>
                            </t:template>
                        </t:Column>

                        <t:Column width="120px">
                            <Label text="SO Number"/>
                            <t:template>
                                <Text text="{salesOrderHeader/salesOrderNumber}"/>
                            </t:template>
                        </t:Column>

                        <t:Column>
                            <Label text="Material"/>
                            <t:template>
                                <Text text="{material}"/>
                            </t:template>
                        </t:Column>

                        <t:Column>
                            <Label text="Quantity"/>
                            <t:template>
                                <Text text="{quantity}"/>
                            </t:template>
                        </t:Column>

                        <t:Column>
                            <Label text="UOM"/>
                            <t:template>
                                <Text text="{uom}"/>
                            </t:template>
                        </t:Column>

                    </t:columns>

                </t:Table>

            </Panel>

        </Panel>

        <!-- ═══════════════════════════════════════════ -->
        <!--               UPDATE SECTION                -->
        <!-- ═══════════════════════════════════════════ -->

        <Panel expandable="false" headerText="Update SO Item"
            class="sapUiLargeMargin sapUiResponsiveMargin"
            visible="{/showUpdatePanel}">

            <f:SimpleForm id="updateSearchForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12"
                adjustLabelSpan="false"
                columnsXL="2"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">

                <f:content>
                    <Label text="Enter Item Number *" />
                    <Input id="searchItemId"
                        value="{/searchItemId}"
                        placeholder="Enter Item Number to search"
                        required="true"/>
                </f:content>

            </f:SimpleForm>

            <Toolbar class="sapUiSmallMargin">
                <Button text="Search &amp; Load" type="Emphasized" press="onSearchItem" icon="sap-icon://search"/>
                <Button text="Back" type="Default" press="onBack" icon="sap-icon://nav-back"/>
            </Toolbar>

            <!-- Edit Panel -->
            <Panel expandable="false" visible="{/editItemMode}" headerText="Edit SO Item"
                class="sapUiLargeMargin sapUiResponsiveMargin">

                <f:SimpleForm id="editItemForm"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="4"
                    labelSpanS="12"
                    adjustLabelSpan="false"
                    columnsXL="2"
                    columnsL="1"
                    columnsM="1"
                    singleContainerFullSize="false">

                    <f:content>
                        <Label text="Item Number" />
                        <Text text="{/editItemPayload/itemNumber}" />

                        <Label text="SO Number" />
                        <Text text="{/editItemPayload/salesOrderHeader/salesOrderNumber}" />

                        <Label text="Material" />
                        <Text text="{/editItemPayload/material}" />

                        <Label text="Quantity *" />
                        <Input id="editItemQuantity"
                            value="{/editItemPayload/quantity}"
                            placeholder="Enter new quantity"
                            type="Number"
                            required="true"/>

                        <Label text="UOM" />
                        <Text text="{/editItemPayload/uom}" />

                    </f:content>

                </f:SimpleForm>

                <Toolbar class="sapUiSmallMargin">
                    <Button text="Update" type="Accept" press="onUpdateItem" icon="sap-icon://save"/>
                    <Button text="Cancel" type="Reject" press="onCancelItemEdit" icon="sap-icon://cancel"/>
                </Toolbar>

            </Panel>

        </Panel>

    </Page>

</mvc:View>